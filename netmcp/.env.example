# NetMCP – optional .env overrides (config can live in mcp.json under "netmcp")
# Prefer mcp.json with: frontend_url, backend_url, storage_backend, netmcp_log_file

# Local file storage (only if storage_backend=file)
# STORAGE_BACKEND=file
# NETMCP_LOG_FILE=netmcp_logs.txt

# App URLs (or set in mcp.json netmcp section)
# FRONTEND_URL=https://your-app.com
# BACKEND_URL=https://your-supabase-project.supabase.co

# Ingest filter – only store these hosts (comma-separated). Or set in mcp.json as ingest_filter_urls.
# INGEST_FILTER_URLS=your-app.com,your-project.supabase.co

# AWS (only when using DynamoDB or deploying Lambda)
# AWS_REGION=us-east-1
# DYNAMO_TABLE=netmcp-requests
